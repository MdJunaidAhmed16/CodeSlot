# CodeSlot Admin — environment

# Backend base URL (Supabase Functions in prod, or the local mock).
VITE_API_BASE_URL=http://localhost:8787

# Production GitHub login via Supabase Auth. Leave BOTH blank to use the local
# dev sign-in (mock backend). Configure the GitHub provider in Supabase Auth.
# Use the PUBLISHABLE key (sb_publishable_...) or legacy anon key — never the secret key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
