# CodeSlot marketing site + advertiser portal.
# Local dev against the mock needs NONE of these (defaults to http://localhost:8787
# and uses the dev email sign-in). Set them for a real deployment:

NEXT_PUBLIC_API_BASE_URL=https://<project-ref>.functions.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-publishable-key>
